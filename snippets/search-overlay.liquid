{% comment %}
  Renders the full-screen predictive search overlay.
{% endcomment %}

<div id="SearchOverlay" class="fixed inset-0 z-50 flex flex-col bg-surface-950/97 backdrop-blur-md hidden" role="dialog" aria-modal="true">
  
  <!-- Search Header Container -->
  <div class="border-b border-white/[0.06] bg-surface-950/80 px-4 sm:px-6 lg:px-8 py-4 sm:py-6">
    <div class="max-w-4xl mx-auto flex items-center justify-between gap-4">
      <div class="relative flex-grow">
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-muted pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input
          type="text"
          id="SearchOverlayInput"
          placeholder="Kart ismi, set adı veya dil arayın..."
          autocomplete="off"
          class="w-full bg-white/[0.03] border border-white/[0.08] focus:border-electric-blue focus:ring-0 focus:outline-none rounded-2xl pl-12 pr-4 py-3.5 text-sm text-white placeholder-muted transition-colors js-search-overlay-input"
        />
      </div>
      
      <button
        type="button"
        class="p-3 rounded-2xl bg-white/[0.02] border border-white/[0.08] text-silver hover:text-white hover:bg-white/[0.04] transition-colors js-search-overlay-close"
        aria-label="Aramayı Kapat"
      >
        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- Search Results / Suggestion Body -->
  <div class="flex-grow overflow-y-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-8 sm:gap-12">
      
      <!-- Left Column: Instant Results / Predictive Match -->
      <div class="md:col-span-8 space-y-6">
        <!-- Results container -->
        <div class="js-search-results-section hidden">
          <h3 class="text-xs font-semibold text-silver uppercase tracking-wider mb-4">
            Eşleşen Koleksiyon Parçaları
          </h3>
          <div class="space-y-3 js-search-results-list">
            <!-- Dynamically populated results -->
          </div>
          
          <button
            type="button"
            class="w-full text-center py-3 rounded-2xl bg-white/[0.02] hover:bg-white/[0.04] border border-white/[0.06] text-xs font-medium text-silver hover:text-white transition-colors mt-4 js-view-all-search-btn"
          >
            Tüm Sonuçları Gör
          </button>
        </div>

        <!-- Default Popular Searches when empty -->
        <div class="space-y-6 js-search-popular-section">
          <h3 class="text-xs font-semibold text-silver uppercase tracking-wider">
            Popüler Koleksiyon Aramaları
          </h3>
          <div class="flex flex-wrap gap-2.5">
            <button
              type="button"
              data-query="Charizard"
              class="flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-white/[0.02] border border-white/[0.08] text-xs text-silver hover:text-white hover:bg-white/[0.04] transition-all hover:-translate-y-0.5 js-popular-chip"
            >
              <svg class="w-3.5 h-3.5 text-electric-blue" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              Charizard
            </button>
            <button
              type="button"
              data-query="Pikachu"
              class="flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-white/[0.02] border border-white/[0.08] text-xs text-silver hover:text-white hover:bg-white/[0.04] transition-all hover:-translate-y-0.5 js-popular-chip"
            >
              <svg class="w-3.5 h-3.5 text-electric-blue" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              Pikachu
            </button>
            <button
              type="button"
              data-query="Booster Box"
              class="flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-white/[0.02] border border-white/[0.08] text-xs text-silver hover:text-white hover:bg-white/[0.04] transition-all hover:-translate-y-0.5 js-popular-chip"
            >
              <svg class="w-3.5 h-3.5 text-electric-blue" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              Booster Box
            </button>
            <button
              type="button"
              data-query="Japonca"
              class="flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-white/[0.02] border border-white/[0.08] text-xs text-silver hover:text-white hover:bg-white/[0.04] transition-all hover:-translate-y-0.5 js-popular-chip"
            >
              <svg class="w-3.5 h-3.5 text-electric-blue" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              Japonca Kartlar
            </button>
            <button
              type="button"
              data-query="ETB"
              class="flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-white/[0.02] border border-white/[0.08] text-xs text-silver hover:text-white hover:bg-white/[0.04] transition-all hover:-translate-y-0.5 js-popular-chip"
            >
              <svg class="w-3.5 h-3.5 text-electric-blue" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              ETB
            </button>
          </div>
        </div>
      </div>

      <!-- Right Column: Recent Searches & Navigation Quick Shortcuts -->
      <div class="md:col-span-4 space-y-8">
        <!-- Recent searches list -->
        <div class="space-y-4 js-search-recent-section hidden">
          <div class="flex items-center justify-between border-b border-white/[0.04] pb-2">
            <h3 class="text-xs font-semibold text-silver uppercase tracking-wider flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-muted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Son Aramalar
            </h3>
            <button
              type="button"
              class="text-[10px] text-muted hover:text-red-400 hover:underline js-clear-recent-searches"
            >
              Temizle
            </button>
          </div>
          <div class="space-y-1.5 js-recent-searches-list">
            <!-- Populated via JS -->
          </div>
        </div>

        <!-- Categories shortcut -->
        <div class="space-y-3">
          <h3 class="text-xs font-semibold text-silver uppercase tracking-wider">
            Koleksiyon Kısayolları
          </h3>
          <div class="grid grid-cols-1 gap-2">
            <a
              href="{{ routes.collections_url }}/japonca-kartlar"
              class="p-3 bg-white/[0.01] border border-white/[0.04] hover:bg-white/[0.03] rounded-xl text-xs text-silver hover:text-white transition-colors flex justify-between items-center"
            >
              <span>🇯🇵 Japonca Tekil Kartlar</span>
              <span class="text-[10px] text-muted">Single</span>
            </a>
            <a
              href="{{ routes.collections_url }}/booster-boxlar"
              class="p-3 bg-white/[0.01] border border-white/[0.04] hover:bg-white/[0.03] rounded-xl text-xs text-silver hover:text-white transition-colors flex justify-between items-center"
            >
              <span>📦 Kapalı Kutu Booster Boxlar</span>
              <span class="text-[10px] text-muted">Sealed</span>
            </a>
            <a
              href="{{ routes.collections_url }}/aksesuarlar"
              class="p-3 bg-white/[0.01] border border-white/[0.04] hover:bg-white/[0.03] rounded-xl text-xs text-silver hover:text-white transition-colors flex justify-between items-center"
            >
              <span>🛡️ Koruyucu TCG Sleeves</span>
              <span class="text-[10px] text-muted">Accessories</span>
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>

</div>
