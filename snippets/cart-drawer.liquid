{% comment %}
  Renders the slide-out cart drawer.
{% endcomment %}

<div id="CartDrawer" class="fixed inset-0 z-50 overflow-hidden hidden" aria-labelledby="slide-over-title" role="dialog" aria-modal="true">
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm transition-opacity duration-300 opacity-0 js-cart-drawer-backdrop"></div>

  <!-- Drawer Wrapper -->
  <div class="absolute inset-y-0 right-0 max-w-full flex pl-10">
    <div class="w-screen max-w-md bg-surface-900 border-l border-white/[0.06] flex flex-col shadow-2xl translate-x-full transition-transform duration-300 ease-in-out js-cart-drawer-panel">
      
      <!-- Header -->
      <div class="p-6 border-b border-white/[0.06] flex items-center justify-between">
        <div class="flex items-center gap-2.5">
          <svg class="w-5 h-5 text-electric-blue" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <h2 class="text-lg font-semibold text-soft-white">{{ 'sections.cart.title' | t }}</h2>
        </div>
        <button
          type="button"
          class="p-1 rounded-lg text-silver hover:text-soft-white hover:bg-white/[0.04] transition-colors js-cart-drawer-close"
        >
          <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>

      <!-- Free Shipping Progress Indicator -->
      <div class="px-6 py-4 bg-white/[0.01] border-b border-white/[0.04] space-y-2 js-cart-shipping-bar">
        <div class="flex justify-between text-xs font-medium">
          <span class="text-silver js-shipping-bar-text">
            Ücretsiz kargo için kalan tutar hesaplanıyor...
          </span>
          <span class="text-muted">₺2.500 Limit</span>
        </div>
        <div class="w-full bg-white/[0.04] h-1.5 rounded-full overflow-hidden">
          <div
            class="h-full bg-gradient-to-r from-electric-blue to-soft-purple rounded-full transition-all duration-500 js-shipping-progress"
            style="width: 0%"
          ></div>
        </div>
      </div>

      <!-- Cart Items List (Dynamically filled via JS) -->
      <div class="flex-1 overflow-y-auto p-6 space-y-6 scrollbar-hide js-cart-items-container">
        <!-- Spinner or empty state placeholder -->
        <div class="h-full flex flex-col items-center justify-center text-center js-cart-empty-state">
          <div class="w-16 h-16 rounded-full bg-white/[0.02] border border-white/[0.06] flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-muted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          </div>
          <p class="text-silver text-sm">{{ 'sections.cart.empty' | t }}</p>
          <button
            type="button"
            class="btn-outline text-xs mt-4 !px-5 !py-2.5 js-cart-drawer-close"
          >
            {{ 'sections.cart.continue_shopping' | t }}
          </button>
        </div>

        <div class="space-y-4 js-cart-drawer-items hidden">
          <!-- Dynamically generated items will be appended here -->
        </div>

        <!-- Cross-sell suggestions -->
        <div class="mt-8 pt-6 border-t border-white/[0.06] space-y-4 js-cart-cross-sells hidden">
          <h3 class="text-xs font-semibold text-silver uppercase tracking-wider">
            Koleksiyonunuzu Koruyun
          </h3>
          <div class="space-y-2.5 js-cross-sells-list">
            <!-- Dynamically populated accessories suggestions -->
          </div>
        </div>
      </div>

      <!-- Footer Details -->
      <div class="p-6 border-t border-white/[0.06] bg-surface-950/40 space-y-4 js-cart-drawer-footer hidden">
        <!-- Trust details -->
        <div class="flex items-center gap-2 px-3 py-2 bg-emerald-500/5 border border-emerald-500/10 rounded-xl text-[10px] text-emerald-400 font-medium">
          <svg class="w-4 h-4 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 9.7a1 1 0 0 1-.68 0C7.5 20.5 4 18 4 13V6a1 1 0 0 1 .76-.97l8-2a1 1 0 0 1 .48 0l8 2A1 1 0 0 1 20 6v7z"/><path d="m9 12 2 2 4-4"/></svg>
          <span>{{ 'sections.cart.trust_badge_text' | t }}</span>
        </div>

        <div class="flex items-center justify-between text-sm">
          <span class="text-silver">{{ 'sections.cart.subtotal' | t }}</span>
          <span class="text-lg font-bold text-soft-white js-cart-drawer-subtotal">₺0,00</span>
        </div>
        
        <p class="text-[11px] text-muted leading-relaxed">
          Kargo ücreti ve vergiler ödeme adımında hesaplanacaktır. Siparişleriniz korumalı zırhlı kutularda gönderilir.
        </p>

        <div class="grid grid-cols-2 gap-3 pt-2">
          <a
            href="{{ routes.cart_url }}"
            class="btn-outline text-center text-xs py-3.5 flex items-center justify-center"
          >
            {{ 'sections.cart.title' | t }}
          </a>
          <a
            href="/checkout"
            class="btn-primary text-center text-xs py-3.5 flex items-center justify-center font-semibold"
          >
            <span>Ödemeye Geç</span>
          </a>
        </div>
      </div>

    </div>
  </div>
</div>
