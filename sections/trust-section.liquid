    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Alt Başlık",
      "default": "Her siparişte üst düzey hizmet ve kusursuz kalite standartları."
    },
    {
      "type": "text",
      "id": "p1_title",
      "label": "Sütun 1 Başlık",
      "default": "Orijinallik Garantisi"
    },
    {
      "type": "textarea",
      "id": "p1_desc",
      "label": "Sütun 1 Açıklama",
      "default": "Tüm kartlar ve kapalı kutular listelenmeden önce uzman ekibimizce orijinallik kontrolünden geçer."
    },
    {
      "type": "text",
      "id": "p2_title",
      "label": "Sütun 2 Başlık",
      "default": "Özel Zırhlı Paketleme"
    },
    {
      "type": "textarea",
      "id": "p2_desc",
      "label": "Sütun 2 Açıklama",
      "default": "Koleksiyon değerini korumak için ultra korumalı, ezilmeye dayanıklı zırhlı kutularda paketleme."
    },
    {
      "type": "text",
      "id": "p3_title",
      "label": "Sütun 3 Başlık",
      "default": "Koleksiyoner Odaklı"
    },
    {
      "type": "textarea",
      "id": "p3_desc",
      "label": "Sütun 3 Açıklama",
      "default": "Koleksiyonculuğu anlıyor ve kart kondisyonlarına tam profesyonellikle yaklaşıyoruz."
    },
    {
      "type": "text",
      "id": "p4_title",
      "label": "Sütun 4 Başlık",
      "default": "24 Saatte Kargo"
    },
    {
      "type": "textarea",
      "id": "p4_desc",
      "label": "Sütun 4 Açıklama",
      "default": "Hafta içi verilen tüm siparişler 24 saat içinde korumalı kargo ile gönderilir."
    }
  ]
}
{% endschema %}
