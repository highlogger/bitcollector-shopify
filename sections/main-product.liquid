{% comment %}
  Renders the main product detail page layout.
{% endcomment %}

{%- liquid
  assign condition = ''
  assign language = ''
  assign rarity = ''
  assign is_new = false
  assign gradient = 'linear-gradient(135deg, #1e1b4b 0%, #311042 100%)'

  for tag in product.tags
    if tag == 'Mint' or tag == 'Near Mint' or tag == 'Excellent' or tag == 'Good'
      assign condition = tag
    endif
    if tag == 'Japonca' or tag == 'İngilizce' or tag == 'Çince' or tag == 'Japanese' or tag == 'English' or tag == 'Chinese'
      assign language = tag
    endif
    if tag == 'Common' or tag == 'Uncommon' or tag == 'Rare' or tag == 'Double Rare' or tag == 'Ultra Rare' or tag == 'Special Illustration Rare' or tag == 'SAR' or tag == 'Promo' or tag == 'Holo' or tag == 'Secret Rare' or tag == 'Special Art'
      assign rarity = tag
    endif
    if tag == 'Yeni' or tag == 'new'
      assign is_new = true
    endif
  endfor

  if rarity == 'Special Illustration Rare' or rarity == 'SAR' or rarity == 'Special Art' or rarity == 'Secret Rare'
    assign gradient = 'linear-gradient(135deg, #3b0764 0%, #0f172a 100%)'
  elsif rarity == 'Ultra Rare'
    assign gradient = 'linear-gradient(135deg, #450a0a 0%, #0f172a 100%)'
  endif
-%}

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-20">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
    
    <!-- Left Column: Image Area -->
    <div class="lg:col-span-6 space-y-6">
      <div 
        class="relative aspect-square w-full rounded-3xl overflow-hidden flex items-center justify-center p-8 border border-white/[0.06] shadow-2xl"
        style="background: {{ gradient }};"
      >
        <!-- Soft ambient back light -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent pointer-events-none"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 rounded-full bg-electric-blue/15 blur-[80px]"></div>

        {%- if product.featured_media != blank -%}
          <img
            src="{{ product.featured_media | image_url: width: 800 }}"
            alt="{{ product.title | escape }}"
            width="{{ product.featured_media.width }}"
            height="{{ product.featured_media.height }}"
            class="object-contain max-h-[85%] max-w-[85%] w-auto h-auto transition-transform duration-700 hover:scale-105 drop-shadow-[0_20px_40px_rgba(59,130,246,0.35)]"
            loading="eager"
            priority
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover bg-surface-800' }}
        {%- endif -%}
      </div>

      <!-- Thumbnails if multiple images exist -->
      {%- if product.media.size > 1 -%}
        <div class="grid grid-cols-4 gap-4">
          {%- for media in product.media -%}
            <div class="relative aspect-square rounded-2xl overflow-hidden border border-white/[0.06] bg-surface-900 cursor-pointer hover:border-white/20 transition-colors">
              <img
                src="{{ media.preview_image | image_url: width: 200 }}"
                alt="{{ product.title | escape }}"
                width="{{ media.width }}"
                height="{{ media.height }}"
                loading="lazy"
                class="object-contain w-full h-full p-2"
              >
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Right Column: Details & Checkout Form -->
    <div class="lg:col-span-6 flex flex-col justify-between space-y-8">
      <div class="space-y-6">
        <div>
          {%- if product.vendor != blank -%}
            <span class="text-xs font-semibold text-electric-blue uppercase tracking-widest block mb-2">
              {{ product.vendor }}
            </span>
          {%- endif -%}
          <h1 class="text-3xl sm:text-4xl font-bold text-white leading-tight">
            {{ product.title }}
          </h1>
        </div>

        <!-- Prices -->
        <div class="flex items-baseline gap-3">
          <span class="text-2xl sm:text-3xl font-bold text-white">
            {{ product.price | money }}
          </span>
          {%- if product.compare_at_price > product.price -%}
            <span class="text-lg text-muted line-through">
              {{ product.compare_at_price | money }}
            </span>
          {%- endif -%}
        </div>

        <!-- Meta Attributes Chips -->
        <div class="grid grid-cols-2 gap-3">
          {%- if language != blank -%}
            <div class="px-4 py-3 bg-white/[0.02] border border-white/[0.04] rounded-2xl text-xs text-silver">
              <span class="text-muted block text-[9px] uppercase tracking-wider mb-1">Dil</span>
              <span class="text-soft-white font-medium">{{ language }}</span>
            </div>
          {%- endif -%}
          {%- if condition != blank -%}
            <div class="px-4 py-3 bg-white/[0.02] border border-white/[0.04] rounded-2xl text-xs text-silver">
              <span class="text-muted block text-[9px] uppercase tracking-wider mb-1">Kondisyon</span>
              <span class="text-soft-white font-medium">{{ condition }}</span>
            </div>
          {%- endif -%}
          {%- if rarity != blank -%}
            <div class="px-4 py-3 bg-white/[0.02] border border-white/[0.04] rounded-2xl text-xs text-silver col-span-2">
              <span class="text-muted block text-[9px] uppercase tracking-wider mb-1">Nadirlik</span>
              <span class="text-soft-white font-medium">{{ rarity }}</span>
            </div>
          {%- endif -%}
        </div>

        <!-- Shopify Cart form -->
        {%- form 'product', product, class: 'space-y-6' -%}
          <input type="hidden" name="id" value="{{ product.first_available_variant.id }}">
          
          {%- if product.available -%}
            <div class="flex items-center gap-4">
              <div class="flex items-center bg-white/[0.03] border border-white/[0.06] rounded-xl p-1.5 h-12">
                <button
                  type="button"
                  class="p-2 rounded-lg text-silver hover:text-soft-white hover:bg-white/[0.04] transition-colors js-qty-minus"
                >
                  <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" x2="19" y1="12" y2="12"/></svg>
                </button>
                <input
                  type="number"
                  name="quantity"
                  value="1"
                  min="1"
                  class="bg-transparent border-0 text-center w-12 text-sm text-soft-white font-medium outline-none focus:ring-0 focus:outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none js-qty-input"
                />
                <button
                  type="button"
                  class="p-2 rounded-lg text-silver hover:text-soft-white hover:bg-white/[0.04] transition-colors js-qty-plus"
                >
                  <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="5" y2="19"/><line x1="5" x2="19" y1="12" y2="12"/></svg>
                </button>
              </div>

              <button
                type="submit"
                class="flex-grow btn-primary h-12 font-bold text-sm flex items-center justify-center gap-2"
              >
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                <span>{{ 'sections.product.add_to_cart' | t }}</span>
              </button>
            </div>
            
            <button
              type="submit"
              name="checkout"
              class="w-full py-3.5 rounded-full bg-white text-surface-950 font-bold hover:bg-white/90 transition-all flex items-center justify-center"
            >
              {{ 'sections.product.buy_now' | t }}
            </button>
          {%- else -%}
            <button
              type="button"
              disabled
              class="w-full py-3.5 rounded-full bg-surface-800 text-muted font-bold border border-white/[0.04] flex items-center justify-center cursor-not-allowed"
            >
              {{ 'sections.product.out_of_stock' | t }}
            </button>
          {%- endif -%}
        {%- endform -%}

        <!-- Trust statements -->
        <div class="pt-4 border-t border-white/[0.06] space-y-3">
          <div class="flex items-center gap-3 text-xs text-silver">
            <svg class="w-5 h-5 text-electric-blue" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 9.7a1 1 0 0 1-.68 0C7.5 20.5 4 18 4 13V6a1 1 0 0 1 .76-.97l8-2a1 1 0 0 1 .48 0l8 2A1 1 0 0 1 20 6v7z"/><path d="m9 12 2 2 4-4"/></svg>
            <div>
              <span class="font-semibold text-soft-white block">{{ 'sections.product.originality_label' | t }}</span>
              <span class="text-[10px] text-muted">{{ 'sections.product.originality_text' | t }}</span>
            </div>
          </div>
          <div class="flex items-center gap-3 text-xs text-silver">
            <svg class="w-5 h-5 text-soft-purple" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="21 8 21 21 3 21 3 8"/><rect width="22" height="5" x="1" y="3"/><line x1="10" x2="14" y1="12" y2="12"/></svg>
            <div>
              <span class="font-semibold text-soft-white block">{{ 'sections.product.shipping_label' | t }}</span>
              <span class="text-[10px] text-muted">{{ 'sections.product.shipping_text' | t }}</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Description Tabs -->
      <div class="border-t border-white/[0.06] pt-6">
        <div class="flex gap-6 border-b border-white/[0.04] pb-2 mb-4">
          <button
            type="button"
            class="text-sm font-semibold text-soft-white border-b-2 border-electric-blue pb-2 outline-none js-tab-btn"
            data-tab="desc"
          >
            {{ 'sections.product.description' | t }}
          </button>
          <button
            type="button"
            class="text-sm font-semibold text-silver pb-2 outline-none hover:text-white js-tab-btn"
            data-tab="shipping"
          >
            {{ 'sections.product.shipping_tab' | t }}
          </button>
        </div>

        <div class="text-xs sm:text-sm text-silver leading-relaxed space-y-4">
          <div class="js-tab-content" data-tab="desc">
            {%- if product.description != blank -%}
              {{ product.description }}
            {%- else -%}
              <p>Bu nadir TCG koleksiyonu parçası için detaylı bir açıklama eklenmedi.</p>
            {%- endif -%}
          </div>
          <div class="js-tab-content hidden" data-tab="shipping">
            <p>{{ 'sections.product.shipping_text' | t }}</p>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Ürün Sayfası İçeriği",
  "settings": []
}
{% endschema %}
