{% comment %}
  Renders the main collection page showing filtered grids and sorting dropdowns.
{% endcomment %}

{%- paginate collection.products by section.settings.products_per_page -%}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-20">
  
  <!-- Collection Header -->
  <div class="mb-12 border-b border-white/[0.04] pb-8">
    <h1 class="text-3xl sm:text-5xl font-extrabold text-white mb-3">
      {{ collection.title }}
    </h1>
    {%- if collection.description != blank -%}
      <div class="text-sm text-silver max-w-3xl leading-relaxed">
        {{ collection.description }}
      </div>
    {%- endif -%}
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
    
    <!-- Left: Sidebar Filters (Simple toggle on mobile, sidebar on desktop) -->
    <aside class="lg:col-span-3 space-y-6">
      <div class="glass-card p-6 rounded-2xl border border-white/[0.06] space-y-6">
        
        <div class="flex items-center justify-between border-b border-white/[0.04] pb-4">
          <h2 class="text-sm font-semibold text-white uppercase tracking-wider flex items-center gap-2">
            <svg class="w-4 h-4 text-electric-blue" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
            {{ 'sections.filters.title' | t }}
          </h2>
          <a href="{{ collection.url }}" class="text-[10px] text-muted hover:text-white hover:underline">
            {{ 'sections.filters.clear_all' | t }}
          </a>
        </div>

        <!-- Dynamic Shopify OS 2.0 Filters -->
        <form class="space-y-6 js-filter-form">
          {%- for filter in collection.filters -%}
            <div class="space-y-3">
              <h3 class="text-xs font-semibold text-silver uppercase tracking-wider">{{ filter.label }}</h3>
              
              <div class="space-y-2 max-h-48 overflow-y-auto pr-1">
                {%- case filter.type -%}
                  {%- when 'list' -%}
                    {%- for value in filter.values -%}
                      <label class="flex items-center gap-2.5 text-xs text-silver cursor-pointer hover:text-white transition-colors">
                        <input
                          type="checkbox"
                          name="{{ value.param_name }}"
                          value="{{ value.value }}"
                          {% if value.active %}checked{% endif %}
                          {% if value.count == 0 and value.active == false %}disabled{% endif %}
                          class="rounded bg-white/[0.02] border-white/[0.08] focus:ring-0 focus:outline-none text-electric-blue w-4 h-4 cursor-pointer"
                        />
                        <span>{{ value.label }} ({{ value.count }})</span>
                      </label>
                    {%- endfor -%}
                  {%- when 'price_range' -%}
                    <div class="flex items-center gap-2">
                      <div class="flex items-center bg-white/[0.02] border border-white/[0.08] rounded-xl px-2 h-9 w-full">
                        <span class="text-[10px] text-muted mr-1">₺</span>
                        <input
                          name="{{ filter.min_value.param_name }}"
                          id="Filter-{{ filter.label }}-Min"
                          {%- if filter.min_value.value -%}
                            value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                          {%- endif -%}
                          type="number"
                          placeholder="0"
                          min="0"
                          max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          class="bg-transparent border-0 p-0 text-xs text-white outline-none focus:ring-0 w-full"
                        />
                      </div>
                      <span class="text-muted text-xs">-</span>
                      <div class="flex items-center bg-white/[0.02] border border-white/[0.08] rounded-xl px-2 h-9 w-full">
                        <span class="text-[10px] text-muted mr-1">₺</span>
                        <input
                          name="{{ filter.max_value.param_name }}"
                          id="Filter-{{ filter.label }}-Max"
                          {%- if filter.max_value.value -%}
                            value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                          {%- endif -%}
                          type="number"
                          placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          min="0"
                          max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          class="bg-transparent border-0 p-0 text-xs text-white outline-none focus:ring-0 w-full"
                        />
                      </div>
                    </div>
                {%- endcase -%}
              </div>
            </div>
          {%- endfor -%}

          <!-- Sorting -->
          <div class="space-y-3 pt-4 border-t border-white/[0.04]">
            <h3 class="text-xs font-semibold text-silver uppercase tracking-wider">{{ 'sections.filters.sort_by' | t }}</h3>
            <select
              name="sort_by"
              class="w-full bg-white/[0.02] border border-white/[0.08] rounded-xl px-3 py-2 text-xs text-silver outline-none focus:border-electric-blue transition-colors cursor-pointer"
            >
              {%- for option in collection.sort_options -%}
                <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>
                  {{ option.name }}
                </option>
              {%- endfor -%}
            </select>
          </div>
          
          <button type="submit" class="w-full btn-primary py-2.5 text-xs font-bold flex items-center justify-center">
            Uygula
          </button>
        </form>

      </div>
    </aside>

    <!-- Right: Product Grid -->
    <div class="lg:col-span-9 space-y-12">
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 lg:gap-6">
        {%- for product in collection.products -%}
          {%- render 'product-card', card_product: product -%}
        {%- else -%}
          <div class="col-span-full py-20 text-center space-y-4">
            <p class="text-silver text-sm">Bu koleksiyonda veya seçili filtrelerde hiç ürün bulunamadı.</p>
            <a href="{{ collection.url }}" class="btn-outline text-xs inline-block">Filtreleri Temizle</a>
          </div>
        {%- endfor -%}
      </div>

      <!-- Pagination Navigation -->
      {%- if paginate.pages > 1 -%}
        <div class="flex items-center justify-center gap-2 pt-6 border-t border-white/[0.04]">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="w-10 h-10 rounded-xl bg-white/[0.02] border border-white/[0.06] hover:border-white/20 text-silver hover:text-white flex items-center justify-center transition-colors">
              <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            </a>
          {%- endif -%}

          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="w-10 h-10 rounded-xl bg-white/[0.02] border border-white/[0.06] hover:border-white/20 text-silver hover:text-white flex items-center justify-center transition-colors text-xs font-medium">
                {{ part.title }}
              </a>
            {%- else -%}
              {%- if part.title == paginate.current_page -%}
                <span class="w-10 h-10 rounded-xl bg-electric-blue text-white flex items-center justify-center text-xs font-bold">
                  {{ part.title }}
                </span>
              {%- else -%}
                <span class="w-10 h-10 text-muted flex items-center justify-center text-xs font-medium">
                  {{ part.title }}
                </span>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="w-10 h-10 rounded-xl bg-white/[0.02] border border-white/[0.06] hover:border-white/20 text-silver hover:text-white flex items-center justify-center transition-colors">
              <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</section>
{%- endpaginate -%}

{% schema %}
{
  "name": "Koleksiyon Liste İçeriği",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 12,
      "max": 48,
      "step": 6,
      "default": 24,
      "label": "Sayfa Başına Ürün"
    }
  ]
}
{% endschema %}
