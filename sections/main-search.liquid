{% comment %}
  Renders the search page content showing matching product grids.
{% endcomment %}

{%- paginate search.results by 24 -%}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-20">
  
  <div class="mb-12 border-b border-white/[0.04] pb-8">
    <h1 class="text-3xl sm:text-5xl font-extrabold text-white mb-4">
      Arama Sonuçları
    </h1>
    
    <!-- Big search bar on results page -->
    <form action="{{ routes.search_url }}" method="get" role="search" class="max-w-xl relative">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'general.search_placeholder' | t }}"
        class="w-full bg-white/[0.02] border border-white/[0.08] focus:border-electric-blue focus:ring-0 focus:outline-none rounded-2xl pl-4 pr-12 py-3 text-sm text-white placeholder-muted transition-colors"
      />
      <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-muted hover:text-white p-1" aria-label="Ara">
        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </button>
    </form>
    
    {%- if search.performed -%}
      <p class="text-xs text-silver mt-4">
        "{{ search.terms | escape }}" için {{ search.results_count }} sonuç bulundu.
      </p>
    {%- endif -%}
  </div>

  {%- if search.performed -%}
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 lg:gap-6">
      {%- for item in search.results -%}
        {%- if item.object_type == 'product' -%}
          {%- render 'product-card', card_product: item -%}
        {%- endif -%}
      {%- else -%}
        <div class="col-span-full py-20 text-center text-silver text-sm">
          Aramanıza uygun ürün bulunamadı. Lütfen farklı kelimelerle tekrar deneyin.
        </div>
      {%- endfor -%}
    </div>

    <!-- Pagination -->
    {%- if paginate.pages > 1 -%}
      <div class="flex items-center justify-center gap-2 pt-12 border-t border-white/[0.04] mt-12">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="w-10 h-10 rounded-xl bg-white/[0.02] border border-white/[0.06] text-silver hover:text-white flex items-center justify-center transition-colors">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </a>
        {%- endif -%}

        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a href="{{ part.url }}" class="w-10 h-10 rounded-xl bg-white/[0.02] border border-white/[0.06] text-silver hover:text-white flex items-center justify-center transition-colors text-xs font-medium">
              {{ part.title }}
            </a>
          {%- else -%}
            {%- if part.title == paginate.current_page -%}
              <span class="w-10 h-10 rounded-xl bg-electric-blue text-white flex items-center justify-center text-xs font-bold">
                {{ part.title }}
              </span>
            {%- else -%}
              <span class="w-10 h-10 text-muted flex items-center justify-center text-xs font-medium">
                {{ part.title }}
              </span>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="w-10 h-10 rounded-xl bg-white/[0.02] border border-white/[0.06] text-silver hover:text-white flex items-center justify-center transition-colors">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  {%- endif -%}

</section>
{%- endpaginate -%}

{% schema %}
{
  "name": "Arama Sonuçları İçeriği",
  "settings": []
}
{% endschema %}
